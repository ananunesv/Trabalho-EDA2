# Copie para .env (que está no .gitignore) e preencha.

# Conexão do Supabase (Project Settings -> Database -> Connection string).
# Use a conexão session/pooler. Se a senha tiver caractere especial, faça
# URL-encode (ex.: @ vira %40).
DATABASE_URL=postgresql://postgres.<ref>:SENHA@aws-0-<regiao>.pooler.supabase.com:5432/postgres

# Chave do Google Gemini (https://aistudio.google.com -> Get API key).
# Usada só pelo gerador de dados fictícios (Fase 6). Tem camada gratuita.
GEMINI_API_KEY=AIza...
